[core]
	autocrlf = false
	editor = vim
	fscache = true
	quotepath = false
	precomposeunicode = true
	preloadindex = true
    excludesfile = ~/.gitignore
	ignorecase = false
	pager = less -R -F -X

[commit]
	gpgsign = true
	verbose = true

[fetch]
	prune = true

[push]
	default = current

[pull]
	rebase = true
	prune = true

[merge]
	ff = false

[branch]
	autosetupmerge = false

[color]
	ui = auto

[alias]
	# shortcut
	s = status
	d = diff
	dc = diff --cached
	dw = diff --ignore-space-change
	sw = switch
	master = checkout master
	main = checkout main
	develop = checkout develop
	dev = checkout develop
	beta = checkout beta

	# http://qiita.com/masarufuruya/items/7480854d4bc2f0443fc1
	graph = log --graph --oneline --decorate

	# for typo
	psuh = push
	puhs = push
	pshu = push

[include]
	path = ~/.gitconfig-personal

[includeIf "hasconfig:remote.*.url:https://github.com/bm-sms/**"]
	path = ~/.gitconfig-work
[includeIf "hasconfig:remote.*.url:git@github.com:bm-sms/**"]
	path = ~/.gitconfig-work

[diff]
	indentHeuristic = true
